# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Client (used for CORS) ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@host:port/db?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
COOKIE_SECRET=your_cookie_secret_signing_key_here
TOKEN_ENCRYPTION_KEY=your_token_encryption_hex_key_here

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1.0/auth/github/callback

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1.0/auth/google/callback

# ─── Mail (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="App Name <your_email@gmail.com>"

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Configuration for Upstash Redis (TLS required, single database).
# Note: Key prefixes are used instead of database indexes (bl: for blacklist, cache: for cache)
REDIS_HOST=your-upstash-redis-endpoint.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_redis_password
REDIS_TLS=true
